{
  "kind": "collectionType",
  "collectionName": "coupons",
  "info": {
    "singularName": "coupon",
    "pluralName": "coupons",
    "displayName": "Coupon",
    "description": "Discount coupons for products and categories"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "discountType": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "percentage",
        "fixed"
      ]
    },
    "value": {
      "type": "decimal",
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "startsAt": {
      "type": "datetime"
    },
    "endsAt": {
      "type": "datetime"
    },
    "minimumSubtotal": {
      "type": "decimal"
    },
    "usageLimit": {
      "type": "integer"
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "mappedBy": "coupons"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "coupons"
    }
  }
}
